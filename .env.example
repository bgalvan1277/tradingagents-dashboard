# ============================================================
# TradingAgents Dashboard Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Authentication ---
# Single password for dashboard access. No user accounts.
DASHBOARD_PASSWORD=changeme
SECRET_KEY=generate-a-random-string-here

# --- Database ---
DATABASE_URL=mysql+aiomysql://tradingagents_user:password@localhost:3306/tradingagents_db
# Sync URL for Alembic migrations (same creds, different driver)
DATABASE_URL_SYNC=mysql+pymysql://tradingagents_user:password@localhost:3306/tradingagents_db

# --- DeepSeek API ---
# Set as OPENAI_API_KEY because TradingAgents uses the OpenAI client
OPENAI_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEP_THINK_MODEL=deepseek-v4-pro
QUICK_THINK_MODEL=deepseek-v4-flash

# --- Cost Protection ---
DAILY_COST_CAP_USD=10.00
MONTHLY_COST_CAP_USD=100.00

# --- Alpha Vantage (optional, framework defaults to yfinance) ---
ALPHA_VANTAGE_API_KEY=

# --- TradingAgents Framework ---
MAX_DEBATE_ROUNDS=2
MAX_RISK_DISCUSS_ROUNDS=1

# --- Cron Schedule ---
# Hour (24h) to run daily analysis on weekdays
CRON_HOUR=7
CRON_MINUTE=0
CRON_TIMEZONE=America/New_York

# --- Server ---
HOST=0.0.0.0
PORT=8000
